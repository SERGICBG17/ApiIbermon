# Copia este archivo como ".env" en la misma carpeta y ajusta los valores.
# El .env real esta en .gitignore - nunca lo subas a git.

# ─── MongoDB ─────────────────────────────────────────────────
# Credenciales root del contenedor mongo. Cambialas en produccion.
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=cambiame_en_produccion

# URI completa (la usan los servicios api/restore/reseed internamente).
# Si cambias MONGO_ROOT_* arriba, ajusta tambien esta cadena.
MONGO_URI=mongodb://admin:cambiame_en_produccion@mongodb:27017/ibermon_db?authSource=admin
MONGO_DB_NAME=ibermon_db

# ─── Puertos del host ────────────────────────────────────────
# Puerto en el que se expone la API al exterior.
# - Local: 8000 (o lo que quieras).
# - Servidor IES Luis Vives: 25013.
API_PORT=8000

# JWT Configuration
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Configuration
APP_NAME=Apilbermon
DEBUG=False

# Gemini (chatbot IberBot) - obtén tu clave en https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
