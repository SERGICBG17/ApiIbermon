# MongoDB Configuration
# Change these values in your actual .env file
MONGO_URI=mongodb://your_username:your_password@mongodb:27017/ibermon_db?authSource=admin
MONGO_DB_NAME=ibermon_db

# JWT Configuration
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_change_this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Configuration
APP_NAME=Apilbermon
DEBUG=False
